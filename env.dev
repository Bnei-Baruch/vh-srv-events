# =============================================================================
# VH-SRV-EVENTS DEVELOPMENT ENVIRONMENT
# =============================================================================
#
# There are 2 sections, App Code and Dev Infra.
# App code is what the code actually uses in common/config.go
# Dev infra is used by Taskfile and dev docker compose infra be it shared or standalone.
#
# Either dev infra mode you use, shared or standalone, you must set Dev Infra section
# and ensure it's in sync with App Code. Mainly DB_* 
#
# In production, we only set App Code section.
#
# TODO (edo): Consolidate POSTGRES_* with DB_* 
#

# =============================================================================
# DEV INFRA
# =============================================================================
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=events

# =============================================================================
# APP CODE
# =============================================================================

APP_PORT=7475
APP_MODE=debug
APP_ENV=dev

DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_DATABASE=events

KEYCLOAK_SERVER_URL=
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

SENTRY_DSN=
